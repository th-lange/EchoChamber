# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echochamber
DB_USER=echochamber
DB_PASSWORD=echochamber

# Security
# Shared bearer token for SnapReq -> /internal/ingest (must match on both sides)
INTERNAL_INGEST_TOKEN=change-me

# Admin console bootstrap (creates the initial ADMIN on first boot if no users exist)
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me
