# Copy to `.env` to override the built-in development defaults.
# `docker compose up` works WITHOUT a .env — these are the same values it falls back to.
# Set real values before exposing the service anywhere beyond local dev.

# Database (used when running the app outside Docker, e.g. ./gradlew bootRun)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echochamber
DB_USER=echochamber
DB_PASSWORD=echochamber

# Security — shared bearer token for SnapReq -> /internal/ingest (must match on both sides).
# Leave EMPTY to disable ingest auth entirely (fine for local dev); set a value to require it.
INTERNAL_INGEST_TOKEN=

# Admin console bootstrap (creates the initial ADMIN on first boot if no users exist).
# First login forces a password change.
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=admin
